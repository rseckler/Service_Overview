{
  "services": {
    "Blackfire_automation": {
      "displayName": "Blackfire Automation",
      "description": "Excel → Notion Sync + Aktienkurs-Updates",
      "type": "cronjob",
      "url": "https://github.com/rseckler/Blackfire_automation",
      "checks": [
        {
          "name": "Stock Price Updates",
          "type": "log-freshness",
          "logPath": "{BASE}/Blackfire_automation/stock_prices.log",
          "maxAgeMinutes": 120
        },
        {
          "name": "Morning Sync",
          "type": "log-freshness",
          "logPath": "{BASE}/Blackfire_automation/sync_cron.log",
          "maxAgeMinutes": 1560
        }
      ]
    },
